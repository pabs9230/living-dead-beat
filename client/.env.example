# Example environment variables for the client (Vite)
# Recommended for production behind nginx with TLS:
# Connect the browser to the proxied secure endpoint. nginx proxies `/ws/` → internal server.
# VITE_WS_URL=wss://game.mawgrim.com/ws

# For local development (HTTP) you can keep a plain ws URL or provide a port:
# VITE_WS_URL=ws://localhost:4041
# VITE_WS_PORT=4041

# Optional: custom path to use instead of the default `/ws` (no trailing slash)
# VITE_WS_PATH=/ws
